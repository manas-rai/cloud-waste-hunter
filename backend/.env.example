# Cloud Waste Hunter - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME=Cloud Waste Hunter
DEBUG=False
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloud_waste_hunter

# ============================================
# AWS Credentials
# ============================================
# Option 1: Use IAM credentials (recommended for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Option 2: Temporary credentials (optional)
# AWS_SESSION_TOKEN=

# Note: If running on EC2/ECS/Lambda, you can leave these empty
# and use IAM roles instead (more secure)

# ============================================
# Detection Thresholds
# ============================================
# EC2 Idle Detection
EC2_IDLE_CPU_THRESHOLD=5.0
EC2_IDLE_DAYS=7

# EBS Unattached Detection
EBS_UNATTACHED_DAYS=30

# Snapshot Detection
SNAPSHOT_AGE_DAYS=90

# ============================================
# Safety Settings
# ============================================
# Enable dry-run mode by default (recommended)
DRY_RUN_ENABLED=True

# Auto-approve actions (NOT recommended for production)
AUTO_APPROVE_ENABLED=False

# Rollback retention period (days)
ROLLBACK_RETENTION_DAYS=7

# ============================================
# ML Model Settings
# ============================================
# Isolation Forest contamination parameter
# Lower = fewer detections, Higher = more detections
ISOLATION_FOREST_CONTAMINATION=0.1

# How often to retrain the ML model (hours)
ML_MODEL_RETRAIN_INTERVAL_HOURS=24
